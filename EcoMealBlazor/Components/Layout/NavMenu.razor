@using EcoMeal.EcoMealBlazor.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<nav class="navbar navbar-dark bg-success">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="navbar-brand fw-bold" href="/">EcoMeal</a>
        <ul class="navbar-nav flex-row gap-2 align-items-center">
            @if (_isLoading)
            {
                <li class="nav-item">
                    <span class="nav-link text-white-50">Loading...</span>
                </li>
            }
            else if (AuthService.IsAuthenticated)
            {
                <li class="nav-item">
                    <span class="nav-link text-white-50">Welcome!</span>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link bg-white text-success rounded-pill px-4 py-2 fw-bold" href="/businesses" Match="NavLinkMatch.All">
                        <span class="bi bi-box-seam me-1" aria-hidden="true"></span> Order
                    </NavLink>
                </li>
                <li class="nav-item">
                    <button class="btn btn-outline-light btn-sm rounded-pill px-3 py-2" @onclick="HandleLogout">
                        <span class="bi bi-box-arrow-right me-1"></span> Logout
                    </button>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <NavLink class="nav-link bg-white text-success rounded-pill px-4 py-2 fw-bold" href="/businesses" Match="NavLinkMatch.All">
                        <span class="bi bi-box-seam me-1" aria-hidden="true"></span> Order
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link text-white rounded-pill px-3 py-2" href="/login">
                        <span class="bi bi-person me-1"></span> Login
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link bg-white text-success rounded-pill px-3 py-2" href="/register">
                        <span class="bi bi-person-plus me-1"></span> Register
                    </NavLink>
                </li>
            }
        </ul>
    </div>
</nav>

@code {
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await AuthService.LoadTokenAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading auth token: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
        
        AuthService.OnChange += StateHasChanged;
    }

    private async Task HandleLogout()
    {
        try
        {
            await AuthService.LogoutAsync();
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during logout: {ex.Message}");
        }
    }

    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
    }
}