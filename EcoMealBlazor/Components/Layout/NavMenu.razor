@inherits NavMenuBase
@using EcoMeal.EcoMealBlazor.Services
@using EcoMeal.EcoMealBlazor.Models
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using EcoMeal.EcoMealBlazor.Resources
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject DarkModeService DarkModeService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> Loc

<nav class="navbar navbar-dark">
    <div class="navbar-content">
        <div class="navbar-brand-group">
            <a href="/" class="navbar-logo-link" title="EcoMeal">
                <img src="/EcoMealIcon.png" alt="EcoMeal" class="navbar-logo" />
            </a>
            <a class="navbar-brand fw-bold" href="/businesses">@Loc["Find your meal!"]</a>
        </div>
        <ul class="navbar-nav">
            @if (_isLoading)
            {
                <li class="nav-item">
                    <span class="nav-link nav-link-loading">@Loc["Loading"]</span>
                </li>
            }
            else if (AuthService.IsAuthenticated)
            {
                <li class="nav-item nav-item-account">
                    <div class="nav-account-link rounded-pill" @onclick="GoToAccount">
                        <span class="bi bi-person-circle me-1"></span>
                        @Loc["Welcome"], @_userName!
                        <span class="nav-role-badge">@_userRole</span>
                    </div>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <NavLink class="nav-link rounded-pill" href="/login">
                        <span class="bi bi-person me-1"></span> @Loc["Login"]
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link nav-link-register rounded-pill" href="/register">
                        <span class="bi bi-person-plus me-1"></span> @Loc["Register"]
                    </NavLink>
                </li>
            }

            <li class="nav-item">
                <button class="dark-mode-toggle @(DarkModeService.IsDarkMode ? "dark" : "")"
                        @onclick="ToggleDarkMode">
                    <span class="toggle-icon sun"><i class="bi bi-sun-fill"></i></span>
                    <span class="toggle-icon moon"><i class="bi bi-moon-fill"></i></span>
                    <div class="toggle-ball"></div>
                </button>
            </li>

                <li class="nav-item">
                    <a class="nav-link nav-link-lastchance rounded-pill" href="/last-chance" title="Last Chance">
                        <i class="bi bi-alarm"></i>
                    </a>
                </li>
                <li class="nav-item">
                    <button class="lang-btn-round" @onclick="GoToLanguages" title="Language">
                        <i class="fa-solid fa-earth-americas"></i>
                    </button>
                </li>
        </ul>
    </div>
</nav>



