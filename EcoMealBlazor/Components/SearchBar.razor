@namespace EcoMeal.EcoMealBlazor.Components
@using EcoMeal.EcoMealBlazor.Models
@using EcoMeal.EcoMealBlazor.Services
@inject NavigationManager NavigationManager

<div class="search-container">
    <div class="search-wrapper">
        <span class="search-icon bi bi-search"></span>
        <input type="text" 
               class="search-input" 
               placeholder="Search..." 
               @bind="SearchTerm"
               @bind:event="oninput"
               @bind:after="OnSearchTermChanged" />
        <button class="search-clear" @onclick="ClearSearch" style="@(_searchTermVisible ? "display: flex;" : "display: none;")">
            <span class="bi bi-x-lg"></span>
        </button>
    </div>
    <div class="search-filters">
        <select class="filter-select" @bind="SelectedType" @bind:after="OnSearchTermChanged">
            <option value="">All Types</option>
            @foreach (var type in BusinessTypes)
            {
                <option value="@type.Name">@type.Name</option>
            }
        </select>
        <select class="filter-select" @bind="SearchBy" @bind:after="OnSearchTermChanged">
            <option value="name">Name</option>
            <option value="address">Address</option>
        </select>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<SearchCriteria> OnSearch { get; set; }

    private string SearchTerm = "";
    private string SelectedType = "";
    private string SearchBy = "name";
    private bool _searchTermVisible = false;
    private List<BusinessTypeModel> BusinessTypes = new();

    [Inject]
    public required BusinessService BusinessService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        BusinessTypes = await BusinessService.GetBusinessTypesAsync();
    }

    private async Task OnSearchTermChanged()
    {
        _searchTermVisible = !string.IsNullOrEmpty(SearchTerm);
        await ApplySearch();
    }

    private async Task ClearSearch()
    {
        SearchTerm = "";
        _searchTermVisible = false;
        await ApplySearch();
    }

    private async Task ApplySearch()
    {
        var criteria = new SearchCriteria
        {
            Term = SearchTerm,
            Type = SelectedType,
            SearchBy = SearchBy
        };
        await OnSearch.InvokeAsync(criteria);
    }

    public class SearchCriteria
    {
        public string Term { get; set; } = "";
        public string Type { get; set; } = "";
        public string SearchBy { get; set; } = "name";
    }
}