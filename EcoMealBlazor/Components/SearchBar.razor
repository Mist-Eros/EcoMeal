@namespace EcoMeal.EcoMealBlazor.Components
@using EcoMeal.EcoMealBlazor.Models
@using EcoMeal.EcoMealBlazor.Services
@inject NavigationManager NavigationManager

<div class="d-flex align-items-center gap-2" style="max-width: 600px;">
    <div class="position-relative flex-grow-1">
        <input type="text" 
               class="form-control rounded-pill" 
               placeholder="Search..." 
               @bind="SearchTerm"
               @bind:event="oninput"
               style="padding-left: 20px;" />
    </div>
    <select class="form-select rounded-pill" style="width: auto; min-width: 140px;" @bind="SelectedType">
        <option value="">All Types</option>
        @foreach (var type in BusinessTypes)
        {
            <option value="@type.Name">@type.Name</option>
        }
    </select>
    <select class="form-select rounded-pill" style="width: auto; min-width: 100px;" @bind="SearchBy">
        <option value="name">Name</option>
        <option value="address">Address</option>
    </select>
    <button class="btn p-0 border-0 bg-transparent" @onclick="ApplySearch" style="transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
        <img src="/EcoMealIcon.png" alt="Search" style="height: 35px; width: 35px; object-fit: contain;" />
    </button>
</div>

@code {
    [Parameter]
    public EventCallback<SearchCriteria> OnSearch { get; set; }

    private string SearchTerm = "";
    private string SelectedType = "";
    private string SearchBy = "name";
    private List<BusinessTypeModel> BusinessTypes = new();

    [Inject]
    public required BusinessService BusinessService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        BusinessTypes = await BusinessService.GetBusinessTypesAsync();
    }

    private async Task ApplySearch()
    {
        var criteria = new SearchCriteria
        {
            Term = SearchTerm,
            Type = SelectedType,
            SearchBy = SearchBy
        };
        await OnSearch.InvokeAsync(criteria);
    }

    public class SearchCriteria
    {
        public string Term { get; set; } = "";
        public string Type { get; set; } = "";
        public string SearchBy { get; set; } = "name";
    }
}