@page "/"
@rendermode InteractiveServer
@using EcoMeal.EcoMealBlazor.Components.BusinessList

<PageTitle>EcoMeal - Home</PageTitle>

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold" style="background: linear-gradient(135deg, #1a472a, #2d6a4f, #40916c); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 0 4px 24px rgba(26, 71, 42, 0.3);">
            EcoMeal
        </h1>
        <p class="lead" style="color: #2d6a4f; text-shadow: 0 2px 8px rgba(45, 106, 79, 0.15); font-weight: 500;">
            "Lettuce help you spend less money :3"
        </p>
        <hr class="w-50 mx-auto" style="border-color: #2d6a4f; box-shadow: 0 2px 8px rgba(45, 106, 79, 0.2);" />
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <BusinessList />
        </div>
    </div>
</div>