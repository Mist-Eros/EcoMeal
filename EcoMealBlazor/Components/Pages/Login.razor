@page "/login"
@inherits LoginBase
@using EcoMeal.EcoMealBlazor.Models.Auth
@using EcoMeal.EcoMealBlazor.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Localization
@using EcoMeal.EcoMealBlazor.Resources
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["Log In"] - EcoMeal</PageTitle>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card form-card">
                <div class="card-body p-4">
                    <h2 class="card-title fw-bold text-success mb-4">
                        <i class="bi bi-box-arrow-in-right me-2"></i>@Loc["Log In"]
                    </h2>

                    @if (_showSuccess)
                    {
                        <div class="alert alert-success d-flex align-items-center" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @Loc["Account created"]
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @_errorMessage
                        </div>
                    }

                    <EditForm Model="_model" OnValidSubmit="HandleLogin" FormName="loginForm">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">@Loc["Email"]</label>
                            <InputText class="form-control rounded-pill dark-input"
                                       @bind-Value="_model.Email"
                                       placeholder="you@example.com" />
                            <ValidationMessage For="() => _model.Email" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">@Loc["Password"]</label>
                            <div class="position-relative">
                                <InputText type="@(_showPassword ? "text" : "password")"
                                           class="form-control rounded-pill dark-input pe-5"
                                           @bind-Value="_model.Password"
                                           placeholder="Enter your password" />
                                <button type="button"
                                        class="position-absolute top-50 end-0 translate-middle-y border-0 bg-transparent me-2 text-secondary"
                                        @onclick="TogglePassword" tabindex="-1"
                                        style="z-index:5;">
                                    <i class="bi @(_showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="() => _model.Password" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-form-save" disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-box-arrow-in-right me-1"></i> @Loc["Log In"]
                            </button>
                            <button type="button" class="btn-form-cancel" @onclick="GoToRegister">
                                @Loc["Register"]
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>



