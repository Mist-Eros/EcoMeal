@page "/account"
@inherits AccountBase
@using EcoMeal.EcoMealBlazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.Extensions.Localization
@using EcoMeal.EcoMealBlazor.Resources
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject HttpClient Http
@inject OrderService OrderService
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResource> Loc

<ConfirmDialog IsVisible="_showConfirm"
               Message="@_confirmMessage"
               ConfirmText="@Loc["Yes"]" CancelText="@Loc["No"]"
               OnConfirm="ExecuteConfirm" OnCancel="() => _showConfirm = false" />

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card form-card">
                <div class="card-body p-4">
                    <h2 class="fw-bold text-success mb-4">
                        <i class="bi bi-person-gear me-2"></i>@Loc["Account Settings"]
                    </h2>

                    @if (_isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-success" role="status">
                                <span class="visually-hidden">@Loc["Loading"]</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <div class="account-info-row">
                                <div class="account-info-icon"><i class="bi bi-envelope"></i></div>
                                <div>
                                    <div class="account-info-label">@Loc["Email"]</div>
                                    <div class="account-info-value">@_userEmail</div>
                                </div>
                            </div>
                            <div class="account-info-row">
                                <div class="account-info-icon"><i class="bi bi-person"></i></div>
                                <div>
                                    <div class="account-info-label">@Loc["Name"]</div>
                                    <div class="account-info-value">@_userName</div>
                                </div>
                            </div>
                            <div class="account-info-row">
                                <div class="account-info-icon"><i class="bi bi-shield-check"></i></div>
                                <div>
                                    <div class="account-info-label">@Loc["Role"]</div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="account-role-badge">@_userRole</span>
                                        <button class="account-edit-btn" @onclick="ToggleEditRole">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (_isEditingRole)
                        {
                            <div class="account-role-editor">
                                <label class="form-label fw-semibold">@Loc["Change Role"]</label>
                                <div class="account-role-picker">
                                    @foreach (var role in _availableRoles)
                                    {
                                        <button class="account-role-option @(_selectedRole == role ? "active" : "")"
                                                @onclick="() => SelectRole(role)"
                                                disabled="@_isLoading">
                                            @role
                                        </button>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(_roleUpdateMessage))
                                {
                                    <div class="mt-2 small @(_roleUpdateSuccess ? "text-success" : "text-danger")">
                                        <i class="bi @(_roleUpdateSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-1"></i>
                                        @_roleUpdateMessage
                                    </div>
                                }
                            </div>
                        }

                        <hr class="account-divider" />

                        @if (!string.IsNullOrEmpty(_clearMessage))
                        {
                            <div class="mt-2 small @(_clearSuccess ? "text-success" : "text-danger")">
                                <i class="bi @(_clearSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-1"></i>
                                @_clearMessage
                            </div>
                        }

                        <button class="account-clear-btn mb-3" @onclick="HandleClearOrders" disabled="@_isClearing">
                            @if (_isClearing)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            <i class="bi bi-trash3 me-1"></i> @Loc["Clear My Order History"]
                        </button>

                        <button class="account-delete-btn mb-3" @onclick="HandleDeleteAccount" disabled="@_isDeleting">
                            @if (_isDeleting)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            <i class="bi bi-person-x me-1"></i> @Loc["Delete My Account"]
                        </button>

                        <hr class="account-divider" />

                        <div class="d-flex gap-2">
                            <button class="btn-form-cancel flex-fill" @onclick="GoToHome">
                                <i class="bi bi-house"></i> @Loc["Back to Home"]
                            </button>
                            <button class="account-logout-btn flex-fill" @onclick="HandleLogout">
                                <i class="bi bi-box-arrow-right"></i> @Loc["Logout"]
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>



