@page "/account"
@using EcoMeal.EcoMealBlazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject HttpClient Http

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card form-card">
                <div class="card-body p-4">
                    <h2 class="fw-bold text-success mb-4">
                        <i class="bi bi-person-gear me-2"></i>Account Settings
                    </h2>

                    @if (_isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-success" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <div class="account-info-row">
                                <div class="account-info-icon"><i class="bi bi-envelope"></i></div>
                                <div>
                                    <div class="account-info-label">Email</div>
                                    <div class="account-info-value">@_userEmail</div>
                                </div>
                            </div>
                            <div class="account-info-row">
                                <div class="account-info-icon"><i class="bi bi-person"></i></div>
                                <div>
                                    <div class="account-info-label">Name</div>
                                    <div class="account-info-value">@_userName</div>
                                </div>
                            </div>
                            <div class="account-info-row">
                                <div class="account-info-icon"><i class="bi bi-shield-check"></i></div>
                                <div>
                                    <div class="account-info-label">Role</div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="account-role-badge">@_userRole</span>
                                        <button class="account-edit-btn" @onclick="ToggleEditRole">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (_isEditingRole)
                        {
                            <div class="account-role-editor">
                                <label class="form-label fw-semibold">Change Role</label>
                                <div class="account-role-picker">
                                    @foreach (var role in _availableRoles)
                                    {
                                        <button class="account-role-option @(_selectedRole == role ? "active" : "")"
                                                @onclick="() => SelectRole(role)"
                                                disabled="@_isUpdating">
                                            @role
                                        </button>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(_roleUpdateMessage))
                                {
                                    <div class="mt-2 small @(_roleUpdateSuccess ? "text-success" : "text-danger")">
                                        <i class="bi @(_roleUpdateSuccess ? "bi-check-circle" : "bi-exclamation-circle") me-1"></i>
                                        @_roleUpdateMessage
                                    </div>
                                }
                            </div>
                        }

                        <hr class="account-divider" />

                        <div class="d-flex gap-2">
                            <button class="btn-form-cancel flex-fill" @onclick="GoToHome">
                                <i class="bi bi-house"></i> Back to Home
                            </button>
                            <button class="account-logout-btn flex-fill" @onclick="HandleLogout">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _isLoading = true;
    private bool _isEditingRole = false;
    private bool _isUpdating = false;
    private bool _roleUpdateSuccess = false;
    private string _userEmail = string.Empty;
    private string _userName = string.Empty;
    private string _userRole = string.Empty;
    private string _selectedRole = string.Empty;
    private string _roleUpdateMessage = string.Empty;
    private List<string> _availableRoles = new() { "User", "Admin" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await LoadUserInfo();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading account: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadUserInfo()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            
            if (user.Identity?.IsAuthenticated == true)
            {
                _userEmail = user.FindFirst(ClaimTypes.Email)?.Value ?? user.Identity?.Name ?? "Unknown";
                _userName = user.FindFirst("Name")?.Value ?? user.Identity?.Name ?? "User";
                _userRole = user.FindFirst(ClaimTypes.Role)?.Value ?? "User";
                _selectedRole = _userRole;
            }
            else
            {
                Navigation.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user info: {ex.Message}");
        }
    }

    private void GoToHome()
    {
        Navigation.NavigateTo("/");
    }

    private void ToggleEditRole()
    {
        _isEditingRole = !_isEditingRole;
        if (_isEditingRole)
        {
            _selectedRole = _userRole;
            _roleUpdateMessage = string.Empty;
        }
        StateHasChanged();
    }

    private async Task SelectRole(string role)
    {
        if (role == _userRole) return;

        _selectedRole = role;
        _roleUpdateMessage = string.Empty;
        StateHasChanged();

        var token = await AuthService.GetTokenAsync();
        Http.DefaultRequestHeaders.Authorization = 
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var encodedEmail = Uri.EscapeDataString(_userEmail);

        try
        {
            var response = await Http.PutAsJsonAsync($"api/users/{encodedEmail}/role", new { Role = role });

            if (response.IsSuccessStatusCode)
            {
                _userRole = role;
                _roleUpdateSuccess = true;
                _roleUpdateMessage = $"Role updated to '{role}'!";
                _isEditingRole = false;

                var roles = new List<string> { role };
                await AuthService.UpdateRolesAsync(roles);

                var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                customProvider.NotifyUserAuthentication(token, roles, _userEmail);

                AuthService.NotifyChanged();

                StateHasChanged();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _roleUpdateSuccess = false;

                try
                {
                    var errorObj = System.Text.Json.JsonSerializer.Deserialize<ErrorResponse>(errorContent);
                    _roleUpdateMessage = errorObj?.Message ?? errorContent;
                }
                catch
                {
                    _roleUpdateMessage = errorContent;
                }
            }
        }
        catch (Exception ex)
        {
            _roleUpdateSuccess = false;
            _roleUpdateMessage = $"Error: {ex.Message}";
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private class ErrorResponse
    {
        public string Message { get; set; }
    }
}
