@page "/business/{BusinessId:int}/package/{PackageId:int}/edit"
@rendermode InteractiveServer
@using EcoMeal.EcoMealBlazor.Models
@using EcoMeal.EcoMealBlazor.Services
@using System.ComponentModel.DataAnnotations
@inject NavigationManager NavigationManager
@inject BusinessService BusinessService

@if (Package == null)
{
    <div class="container my-4 text-center">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
    return;
}

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h2 class="card-title fw-bold text-success mb-4">
                        <i class="bi bi-pencil-square me-2"></i>Edit Package
                    </h2>

                    <EditForm Model="EditModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Name</label>
                            <InputText class="form-control rounded-pill" @bind-Value="EditModel.Name" placeholder="Package name..." />
                            <ValidationMessage For="@(() => EditModel.Name)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <InputTextArea class="form-control rounded-4" @bind-Value="EditModel.Description" placeholder="Describe the package..." rows="3" />
                            <ValidationMessage For="@(() => EditModel.Description)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Price (RON)</label>
                            <InputNumber class="form-control rounded-pill" @bind-Value="EditModel.Price" placeholder="0.00" step="0.01" min="0" />
                            <ValidationMessage For="@(() => EditModel.Price)" class="text-danger small" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Pickup Start</label>
                                <InputDate class="form-control rounded-pill" @bind-Value="EditModel.Start_PickUp" />
                                <ValidationMessage For="@(() => EditModel.Start_PickUp)" class="text-danger small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Pickup End</label>
                                <InputDate class="form-control rounded-pill" @bind-Value="EditModel.End_PickUp" />
                                <ValidationMessage For="@(() => EditModel.End_PickUp)" class="text-danger small" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Package Type</label>
                            <InputSelect class="form-select rounded-pill" @bind-Value="EditModel.PackageTypeId">
                                <option value="" disabled>Select a type...</option>
                                @foreach (var type in PackageTypes)
                                {
                                    <option value="@type.Id">@type.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => EditModel.PackageTypeId)" class="text-danger small" />
                        </div>

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger">@ErrorMessage</div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success rounded-pill px-4" disabled="@IsSubmitting">
                                @if (IsSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-check-lg me-1"></i> Save
                            </button>
                            <button type="button" class="btn btn-outline-secondary rounded-pill px-4" @onclick="GoBack">
                                Cancel
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public int BusinessId { get; set; }

    [Parameter]
    public int PackageId { get; set; }

    private PackageEditModel EditModel = new();
    private PackageGetModel? Package;
    private List<PackageTypeModel> PackageTypes = new();
    private bool IsSubmitting = false;
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        Package = await BusinessService.GetPackageByIdAsync(PackageId);
        if (Package != null)
        {
            EditModel = new PackageEditModel
            {
                Id = Package.Id,
                Name = Package.Name,
                Description = Package.Description,
                Price = Package.Price,
                Start_PickUp = Package.Start_PickUp,
                End_PickUp = Package.End_PickUp,
                PackageTypeId = Package.PackageTypeId
            };
        }
        PackageTypes = await BusinessService.GetPackageTypesAsync();
    }

    private async Task HandleSubmit()
    {
        IsSubmitting = true;
        ErrorMessage = null;

        var success = await BusinessService.UpdatePackageAsync(EditModel);
        if (success)
        {
            NavigationManager.NavigateTo($"/business/{BusinessId}");
        }
        else
        {
            ErrorMessage = "Something went wrong. Please try again.";
            IsSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo($"/business/{BusinessId}");
    }
}