@page "/my-orders"
@using EcoMeal.EcoMealBlazor.Services
@using EcoMeal.EcoMealBlazor.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.Extensions.Localization
@using EcoMeal.EcoMealBlazor.Resources
@inject OrderService OrderService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@inject BusinessService BusinessService
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["My Orders"]</PageTitle>

<div class="myorders-container">
    <div class="myorders-header">
        <div class="myorders-tabs">
            <button class="myorders-tab @(_activeTab == "orders" ? "active" : "")"
                    @onclick="SwitchToOrders">
                <i class="bi bi-bag-check me-1"></i>@Loc["My Orders"]
            </button>
            <button class="myorders-tab @(_activeTab == "history" ? "active" : "")"
                    @onclick="SwitchToHistory">
                <i class="bi bi-clock-history me-1"></i>@Loc["Order History"]
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">@Loc["Loading"]</span>
            </div>
        </div>
    }
    else if (_showRating)
    {
        <div class="myorders-rating-overlay">
            <div class="myorders-rating-card">
                <h4 class="myorders-rating-title">
                    <i class="fa-solid fa-pizza-slice me-1"></i> @Loc["Rate"] @_ratingBusinessName
                </h4>
                <p class="myorders-rating-sub">@Loc["How was your experience"]</p>
                <div class="myorders-rating-stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var star = i;
                        <button class="myorders-rating-star @(star <= _ratingValue ? "filled" : "") @(star <= _ratingHover ? "hover" : "")"
                                @onclick="() => SubmitRating(star)"
                                @onmouseover="() => HoverStar(star)"
                                @onmouseout="ResetHover">
                            <i class="bi @(star <= (_ratingHover > 0 ? _ratingHover : _ratingValue) ? "bi-star-fill" : "bi-star")"></i>
                        </button>
                    }
                </div>
                <button class="myorders-rating-submit" @onclick="ConfirmRating" disabled="@(_ratingValue == 0 || _ratingSubmitting)">
                    @if (_ratingSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <span>@Loc["Saving"]</span>
                    }
                    else if (_ratingIndex < _ratingBusinesses.Count - 1)
                    {
                        <span>@Loc["Next"] <i class="bi bi-arrow-right ms-1"></i></span>
                    }
                    else
                    {
                        <span>@Loc["Done"] <i class="bi bi-check-lg ms-1"></i></span>
                    }
                </button>
                @if (!string.IsNullOrEmpty(_ratingError))
                {
                    <p class="myorders-rating-error">@_ratingError</p>
                }
            </div>
        </div>
    }
    else if (!_orders.Any())
    {
        <div class="myorders-empty">
            <i class="bi @(_activeTab == "history" ? "bi-clock-history" : "bi-box-seam") myorders-empty-icon"></i>
            <h5>@(_activeTab == "history" ? Loc["No order history"] : Loc["No pending orders"])</h5>
            <p>@(_activeTab == "history" ? Loc["No order history"] : Loc["No pending orders"])</p>
            @if (_activeTab == "orders")
            {
                <button class="myorders-browse-btn" @onclick="GoToBusinesses">
                    <i class="bi bi-compass me-1"></i> @Loc["Browse Businesses"]
                </button>
            }
        </div>
    }
    else
    {
        <div class="myorders-list">
            @foreach (var order in _orders)
            {
                <div class="myorders-card">
                    <div class="myorders-card-main">
                        <div class="myorders-card-left">
                            <div class="myorders-card-icon">
                                <i class="bi @(order.Status == 2 ? "bi-check2-circle" : "bi-box-seam")"></i>
                            </div>
                        </div>
                        <div class="myorders-card-body">
                            <div class="myorders-card-top">
                                <h5 class="myorders-package-name">@order.PackageName</h5>
                                <span class="myorders-status-badge @StatusClass(order.Status)">@Loc[StatusLabel(order.Status)]</span>
                            </div>
                            <div class="myorders-card-details">
                                <span class="myorders-detail">
                                    <i class="bi bi-shop me-1"></i>@order.BusinessName
                                </span>
                                @if (_isAdmin && !string.IsNullOrEmpty(order.UserEmail))
                                {
                                    <span class="myorders-detail myorders-user">
                                        <i class="bi bi-person me-1"></i>@order.UserEmail
                                    </span>
                                }
                                <span class="myorders-detail">
                                    <i class="bi bi-calendar3 me-1"></i>@order.Date.ToString("dd.MM.yyyy")
                                </span>
                                <span class="myorders-detail">
                                    <i class="bi bi-clock me-1"></i>@order.Date.ToString("HH:mm")
                                </span>
                            </div>
                        </div>
                        <div class="myorders-card-right">
                            <div class="myorders-price">@order.Price.ToString("F2") RON</div>
                        </div>
                    </div>
                    @if (_activeTab == "orders" && order.Status == 1)
                    {
                        <div class="myorders-card-actions">
                            <button class="myorders-pickup-btn"
                                    @onclick="() => HandlePickup(order.Id, order.businessId, order.BusinessName)"
                                    @onclick:stopPropagation="true">
                                <i class="bi bi-check-lg"></i> @Loc["Picked Up"]
                            </button>
                            <button class="myorders-cancel-btn"
                                    @onclick="() => HandleCancel(order.Id)"
                                    @onclick:stopPropagation="true">
                                <i class="bi bi-x-lg"></i> @Loc["Cancel"]
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        @if (_activeTab == "orders" && _orders.Any(o => o.Status == 1))
        {
            <div class="myorders-discount">
                <div class="myorders-discount-header">
                    <i class="bi bi-star-fill"></i>
                    <span>@Loc["Loyalty Discount"] — @_discountPercent% off (@_orderCount package@(_orderCount != 1 ? "s" : ""))</span>
                </div>
                @if (_discountPercent > 0)
                {
                    <div class="myorders-discount-rows">
                        <div class="myorders-discount-row">
                            <span>@Loc["Total price"]</span>
                            <span class="myorders-discount-old">@_totalPrice.ToString("F2") RON</span>
                        </div>
                        <div class="myorders-discount-row">
                            <span>@Loc["You save"] (@_discountPercent%)</span>
                            <span class="myorders-discount-save">-@_savedAmount.ToString("F2") RON</span>
                        </div>
                        <div class="myorders-discount-row myorders-discount-final">
                            <span>@Loc["Final price"]</span>
                            <span>@_finalPrice.ToString("F2") RON</span>
                        </div>
                    </div>
                }
                @if (!_isAdmin && _orderCount > 0)
                {
                    <button class="myorders-pickup-all-btn" @onclick="HandlePickUpAll">
                        <i class="bi bi-check2-all me-1"></i> @Loc["Pick Up All Packages"]
                    </button>
                }
            </div>
        }
    }
</div>

@code {
    private string _activeTab = "orders";
    private bool _isLoading = true;
    private bool _isAdmin = false;
    private List<OrderGetModel> _orders = new();
    private int _orderCount = 0;
    private int _discountPercent = 0;
    private double _totalPrice = 0;
    private double _savedAmount = 0;
    private double _finalPrice = 0;

    private bool _showRating = false;
    private List<(int BusinessId, string Name)> _ratingBusinesses = new();
    private int _ratingIndex = 0;
    private string _ratingBusinessName = "";
    private int _ratingValue = 0;
    private int _ratingHover = 0;
    private bool _ratingSubmitting = false;
    private string _ratingError = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Admin");

        await LoadOrders();
        _isLoading = false;
    }

    private async Task LoadOrders()
    {
        if (_activeTab == "orders")
        {
            _orders = _isAdmin
                ? await OrderService.GetAllOrdersAsync()
                : await OrderService.GetMyOrderAsync();

            var pending = _orders.Where(o => o.Status == 1).ToList();
            _orderCount = pending.Count;
            _discountPercent = pending.Count * 5;
            _totalPrice = pending.Sum(o => o.Price);
            _savedAmount = _totalPrice * _discountPercent / 100.0;
            _finalPrice = _totalPrice - _savedAmount;
        }
        else
        {
            _orders = await OrderService.GetOrderHistoryAsync();
            _discountPercent = 0;
            _orderCount = 0;
        }
    }

    private async Task SwitchToOrders() => await SwitchTab("orders");
    private async Task SwitchToHistory() => await SwitchTab("history");

    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        _isLoading = true;
        StateHasChanged();

        await LoadOrders();
        _isLoading = false;
    }

    private async Task HandlePickup(int orderId, int businessId, string businessName)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", Loc["Mark picked up"].ToString());
        if (!confirmed) return;

        var success = await OrderService.MarkPickedUpAsync(orderId);
        if (success)
        {
            await LoadOrders();
            StartRating(new List<(int, string)> { (businessId, businessName) });
        }
    }

    private async Task HandleCancel(int orderId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", Loc["Confirm cancel"].ToString());
        if (!confirmed) return;

        var success = await OrderService.CancelOrderAsync(orderId);
        if (success)
        {
            await LoadOrders();
            StateHasChanged();
        }
    }

    private async Task HandlePickUpAll()
    {
        var msg = string.Format(Loc["Confirm pick up all"].ToString(), _orderCount, _finalPrice.ToString("F2"), _discountPercent);
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", msg);
        if (!confirmed) return;

        var pending = _orders.Where(o => o.Status == 1).ToList();
        var uniqueBusinesses = pending
            .Select(o => (o.businessId, o.BusinessName))
            .Distinct()
            .ToList();

        var success = await OrderService.MarkAllPickedUpAsync();
        if (success)
        {
            await LoadOrders();
            StartRating(uniqueBusinesses);
        }
    }

    private void StartRating(List<(int BusinessId, string Name)> businesses)
    {
        if (businesses.Count == 0)
        {
            _showRating = false;
            StateHasChanged();
            return;
        }

        _ratingBusinesses = businesses;
        _ratingIndex = 0;
        _ratingValue = 0;
        _ratingHover = 0;
        _ratingBusinessName = businesses[0].Name;
        _showRating = true;
        StateHasChanged();
    }

    private async Task SubmitRating(int stars)
    {
        _ratingValue = stars;
        _ratingHover = 0;
    }

    private void HoverStar(int star) { _ratingHover = star; }
    private void ResetHover() { _ratingHover = 0; }

    private async Task ConfirmRating()
    {
        if (_ratingValue == 0) return;

        _ratingSubmitting = true;
        _ratingError = "";
        StateHasChanged();

        var (businessId, _) = _ratingBusinesses[_ratingIndex];
        var success = await BusinessService.RateBusinessAsync(businessId, _ratingValue);

        if (!success)
        {
            _ratingError = Loc["Failed to save rating"].ToString();
            _ratingSubmitting = false;
            StateHasChanged();
            return;
        }

        if (_ratingIndex < _ratingBusinesses.Count - 1)
        {
            _ratingIndex++;
            _ratingValue = 0;
            _ratingHover = 0;
            _ratingBusinessName = _ratingBusinesses[_ratingIndex].Name;
            _ratingSubmitting = false;
        }
        else
        {
            _showRating = false;
        }

        StateHasChanged();
    }

    private string StatusLabel(int status) => status switch
    {
        1 => "Placed",
        2 => "Picked Up",
        0 => "Cancelled",
        _ => "Unknown"
    };

    private string StatusClass(int status) => status switch
    {
        1 => "status-placed",
        2 => "status-picked",
        0 => "status-cancelled",
        _ => ""
    };

    private void GoToBusinesses()
    {
        NavigationManager.NavigateTo("/businesses");
    }
}
