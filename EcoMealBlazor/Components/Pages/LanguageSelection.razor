@page "/languages"
@rendermode InteractiveServer
@using System.Globalization
@using Microsoft.Extensions.Localization
@using EcoMeal.EcoMealBlazor.Resources
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> Loc

<PageTitle>@Loc["Select Language"] — EcoMeal</PageTitle>

<div class="lang-page">
    <h2 class="lang-title">@Loc["Select Language"]</h2>

    <div class="lang-list">
        @for (int i = 0; i < _languages.Length; i++)
        {
            var idx = i;
            var isSelected = CurrentIndex == idx;
            <button class="lang-option @(isSelected ? "selected" : "")"
                    @onclick="() => SelectLanguage(idx)">
                <span class="lang-flag">@_languages[idx].flag</span>
                <div class="lang-info">
                    <span class="lang-native-name">@_languages[idx].nativeName</span>
                    <span class="lang-english-name">@_languages[idx].englishName</span>
                </div>
                @if (isSelected)
                {
                    <span class="lang-check"><i class="bi bi-check-lg"></i></span>
                }
            </button>
        }
    </div>
</div>

@code
{
    private (string code, string name, string culture, string nativeName, string englishName, string flag)[] _languages = new[]
    {
        ("EN", "English", "en-US", "English (US)", "English", "\ud83c\uddfa\ud83c\uddf8"),
        ("GB", "English", "en-GB", "English (UK)", "English", "\ud83c\uddec\ud83c\udde7"),
        ("RO", "Rom\u00e2n\u0103", "ro-RO", "Rom\u00e2n\u0103", "Romanian", "\ud83c\uddf7\ud83c\uddf4"),
        ("DE", "Deutsch", "de-DE", "Deutsch", "German", "\ud83c\udde9\ud83c\uddea"),
        ("FR", "Fran\u00e7ais", "fr-FR", "Fran\u00e7ais", "French", "\ud83c\uddeb\ud83c\uddf7"),
        ("RS", "\u0421\u0440\u043f\u0441\u043a\u0438", "sr-RS", "\u0421\u0440\u043f\u0441\u043a\u0438", "Serbian", "\ud83c\uddf7\ud83c\uddf8"),
        ("FI", "Suomi", "fi-FI", "Suomi", "Finnish", "\ud83c\uddeb\ud83c\uddee"),
        ("JP", "\u65e5\u672c\u8a9e", "ja-JP", "\u65e5\u672c\u8a9e", "Japanese", "\ud83c\uddef\ud83c\uddf5"),
        ("SA", "\u0627\u0644\u0639\u0631\u0628\u064a\u0629", "ar-SA", "\u0627\u0644\u0639\u0631\u0628\u064a\u0629", "Arabic", "\ud83c\uddf8\ud83c\udde6"),
    };

    private int CurrentIndex
    {
        get
        {
            var current = CultureInfo.CurrentCulture.Name;
            for (int i = 0; i < _languages.Length; i++)
                if (_languages[i].culture == current) return i;
            return 0;
        }
    }

    private async Task SelectLanguage(int idx)
    {
        if (idx == CurrentIndex) return;
        await JS.InvokeVoidAsync("blazorCulture.set", _languages[idx].culture);
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true, replace: true);
    }
}
