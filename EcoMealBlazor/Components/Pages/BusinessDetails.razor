@page "/business/{Id:int}"
@using EcoMeal.EcoMealBlazor.Models
@using EcoMeal.EcoMealBlazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject BusinessService BusinessService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider

@if (Business == null)
{
    <div class="container my-4 text-center">
        <div class="spinner-border text-success" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
    return;
}

<div class="container my-4">
    <div class="card shadow-sm mb-4 border-0 rounded-4 overflow-hidden">
        <img src="@GetBusinessImage()" class="card-img-top" alt="@Business.Name" style="height: 250px; object-fit: cover;" />
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="display-5 fw-bold text-success mb-2">@Business.Name</h1>
                    <p class="text-muted lead mb-3">@Business.Description</p>
                </div>
                <span class="badge rounded-pill px-4 py-2" style="background-color: #1e4d2b; color: white; font-size: 1rem;">@Business.BusinessTypeName</span>
            </div>
            <hr />
            <div class="row g-3">
                <div class="col-md-6">
                    <i class="bi bi-geo-alt text-success me-2"></i>
                    <span class="text-muted">@Business.Address</span>
                </div>
                <div class="col-md-6">
                    <i class="bi bi-telephone text-success me-2"></i>
                    <span class="text-muted">@Business.Contact</span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h2 class="fw-bold text-success"><i class="bi bi-box-seam me-2"></i>Packages</h2>
        
        @if (_isAdmin)
        {
            <button class="btn btn-success rounded-pill px-4" @onclick="NavigateToAddPackage">
                <i class="bi bi-plus-lg me-1"></i> Add Package
            </button>
        }
    </div>

    @if (Business.Packages != null && Business.Packages.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var package in Business.Packages)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 hover-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold text-success">@package.Name</h5>
                                <span class="badge bg-primary rounded-pill px-3 py-2">@package.PackageTypeName</span>
                            </div>
                            <p class="card-text text-muted small">@package.Description</p>
                            <div class="mt-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-success fs-5">@package.Price.ToString("C")</span>
                                    <span class="text-muted small">
                                        <i class="bi bi-clock me-1"></i>
                                        @package.Start_PickUp.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </div>
                                <div class="text-muted small mt-1">
                                    <i class="bi bi-clock-history me-1"></i>
                                    Until: @package.End_PickUp.ToString("dd/MM/yyyy HH:mm")
                                </div>
                                <div class="d-flex gap-2 mt-3">
                                    @if (_isAdmin)
                                    {
                                        <button class="btn btn-outline-primary rounded-pill flex-fill" @onclick="() => NavigateToEditPackage(package.Id)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                        <button class="btn btn-outline-danger rounded-pill flex-fill" @onclick="() => DeletePackage(package.Id)" @onclick:stopPropagation="true">
                                            <i class="bi bi-trash3"></i> Delete
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-success rounded-pill flex-fill" @onclick="() => OrderPackage(package.Id)">
                                            <i class="bi bi-cart"></i> Order
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-box-seam fs-1 text-muted"></i>
            <p class="text-muted mt-3">No packages available for this business.</p>
            
            @if (_isAdmin)
            {
                <button class="btn btn-success rounded-pill mt-2" @onclick="NavigateToAddPackage">
                    <i class="bi bi-plus-lg me-1"></i> Add First Package
                </button>
            }
        </div>
    }

    <div class="mt-4">
        <button class="btn btn-outline-secondary rounded-pill px-4" @onclick="GoBack">
            <i class="bi bi-arrow-left me-1"></i> Back
        </button>
    </div>
</div>

<style>
    .hover-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private BusinessDetailsModel? Business;
    private bool _isAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        Business = await BusinessService.GetOneById(Id);
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _isAdmin = user.IsInRole("Admin");
    }

    private string GetBusinessImage()
    {
        var type = Business?.BusinessTypeName?.ToLower() ?? "";
        
        if (type.Contains("restaurant"))
            return "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800&h=400&fit=crop";
        else if (type.Contains("fast food") || type.Contains("fast-food"))
            return "https://images.unsplash.com/photo-1571091718767-18b5b1457add?w=800&h=400&fit=crop";
        else if (type.Contains("bakery"))
            return "https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=800&h=400&fit=crop";
        else
            return "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=800&h=400&fit=crop";
    }

    private void NavigateToAddPackage()
    {
        NavigationManager.NavigateTo($"/business/{Id}/addpackage");
    }

    private void NavigateToEditPackage(int packageId)
    {
        NavigationManager.NavigateTo($"/business/{Id}/package/{packageId}/edit");
    }

    private async Task DeletePackage(int packageId)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this package?");
        if (confirmed)
        {
            var success = await BusinessService.DeletePackageAsync(packageId);
            if (success)
            {
                Business = await BusinessService.GetOneById(Id);
                StateHasChanged();
            }
        }
    }

    private void OrderPackage(int packageId)
    {
        // Navigate to order page for this package
        NavigationManager.NavigateTo($"/business/{Id}/package/{packageId}/order");
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/businesses/");
    }
}