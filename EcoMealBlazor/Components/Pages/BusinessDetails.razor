@page "/business/{Id:int}"
@inherits BusinessDetailsBase
<!-- business detail: image, info, rating, packages, qr code -->
@using EcoMeal.EcoMealBlazor.Models
@using EcoMeal.EcoMealBlazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using EcoMeal.EcoMealBlazor.Resources
@inject BusinessService BusinessService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResource> Loc
@inject CurrencyService Currency

<ConfirmDialog IsVisible="_showDeleteConfirm"
               Message="@_confirmMessage"
               ConfirmText="@Loc["Yes"]" CancelText="@Loc["No"]"
               OnConfirm="ExecuteDeletePackage" OnCancel="() => _showDeleteConfirm = false" />

@if (Business == null)
{
    <div class="container my-5 text-center">
        <div class="spinner-border text-success" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">@Loc["Loading"]</span>
        </div>
    </div>
    return;
}

<div class="details-container">
    <div class="details-business-card">
        <img src="@GetBusinessImage()" class="details-business-image" alt="@Business.Name" />
        <div class="details-business-body">
            <div class="details-business-header">
                <div>
                    <h1 class="details-business-title">@Business.Name</h1>
                    <p class="details-business-description">@Business.Description</p>
                </div>
                <span class="details-business-badge"><i class="@GetTypeIcon() me-1"></i>@LocTypeName()</span>
            </div>
            <hr class="details-divider" />
            <div class="details-info-row">
                <div class="details-business-info">
                    <div class="details-info-item">
                        <i class="bi bi-geo-alt details-info-icon"></i>
                        <span>@Business.Address</span>
                    </div>
                    <div class="details-info-item">
                        <i class="bi bi-telephone details-info-icon"></i>
                        <span>@Business.Contact</span>
                    </div>
                </div>
                <div class="details-qr-thumb" @onclick="() => _showQrModal = true" title="@Loc["Tap to enlarge"]">
                    <img src="@GetQRUrl()" alt="QR Code" />
                </div>
            </div>

            <div class="details-rating">
                <div class="details-rating-stars">
                    @{
                        var fullStars = (int)Math.Floor(Business.AverageRating);
                        var remainder = Business.AverageRating - fullStars;
                        var hasHalf = remainder >= 0.25 && remainder < 0.75;
                        var extraFull = remainder >= 0.75;
                    }
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= fullStars)
                        {
                            <span class="details-star filled"><i class="bi bi-star-fill"></i></span>
                        }
                        else if (i == fullStars + 1 && hasHalf)
                        {
                            <span class="details-star filled"><i class="bi bi-star-half"></i></span>
                        }
                        else if (i == fullStars + 1 && extraFull)
                        {
                            <span class="details-star filled"><i class="bi bi-star-fill"></i></span>
                        }
                        else
                        {
                            <span class="details-star"><i class="bi bi-star"></i></span>
                        }
                    }
                </div>
                <span class="details-rating-text">
                    @Business.AverageRating.ToString("F1") (@Business.TotalRatings @(Business.TotalRatings == 1 ? Loc["Rating"].Value : Loc["Ratings"].Value))
                </span>
            </div>
        </div>
    </div>

    <div class="details-packages-header">
        <h2 class="details-packages-title">
            <i class="bi bi-box-seam details-packages-icon"></i>@Loc["Menu"]
        </h2>
        
        @if (_isAdmin)
        {
            <button class="details-add-btn" @onclick="NavigateToAddPackage">
                <i class="bi bi-plus-lg"></i> @Loc["Add Package"]
            </button>
        }
    </div>

    @if (Business.Packages != null && Business.Packages.Any())
    {
        var visiblePackages = _isAdmin
            ? Business.Packages
            : Business.Packages.Where(p => p.Start_PickUp <= DateTime.Now && DateTime.Now <= p.End_PickUp).ToList();

        @if (!visiblePackages.Any())
        {
            <div class="details-empty-state">
                <i class="bi bi-box-seam details-empty-icon"></i>
                <p class="details-empty-text">@Loc["No menu items"]</p>
            </div>
        }
        else
        {
        <div class="details-packages-grid">
            @foreach (var package in visiblePackages)
            {
                var now = DateTime.Now;
                var isExpired = package.End_PickUp <= now;
                var isAvailable = package.Start_PickUp <= now && now <= package.End_PickUp;
                var statusClass = isExpired ? "expired" : isAvailable ? "available" : "upcoming";
                <div class="details-package-card @statusClass">
                    <div class="details-package-image-wrapper">
                        <img src="@GetPackageImage(package.PackageTypeName)" class="details-package-image" alt="@package.Name" />
                    </div>
                    <div class="details-package-body">
                        <div class="details-package-header">
                            <h5 class="details-package-title">@package.Name</h5>
                            <span class="details-package-badge">@package.PackageTypeName</span>
                        </div>
                        
                        <p class="details-package-description">@package.Description</p>
                        
                        <div class="details-package-footer">
                            <div class="details-package-price-row">
                                <span class="details-package-price">@Currency.Format(package.Price)</span>
                                <div class="details-package-times">
                                    <div class="details-package-time-row">
                                        <i class="bi bi-clock"></i>
                                        <span>From: @package.Start_PickUp.ToString("HH:mm")</span>
                                    </div>
                                    <div class="details-package-time-row">
                                        <i class="bi bi-clock-history"></i>
                                        <span>Until: @package.End_PickUp.ToString("HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="details-package-actions">
                            @if (_isAdmin)
                            {
                                <button class="details-package-edit-btn" @onclick="() => NavigateToEditPackage(package.Id)">
                                    <i class="bi bi-pencil"></i> @Loc["Edit"]
                                </button>
                                <button class="details-package-delete-btn" @onclick="() => DeletePackage(package.Id)" @onclick:stopPropagation="true">
                                    <i class="bi bi-trash3"></i> @Loc["Delete"]
                                </button>
                            }
                            else
                            {
                                <button class="details-package-order-btn" @onclick="() => OrderPackage(package.Id)">
                                    <i class="bi bi-cart"></i> @Loc["Order Now"]
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        }
    }
    else
    {
        <div class="details-empty-state">
            <i class="bi bi-box-seam details-empty-icon"></i>
            <p class="details-empty-text">@Loc["No menu items"]</p>
            
            @if (_isAdmin)
            {
                <button class="details-add-btn details-add-first-btn" @onclick="NavigateToAddPackage">
                    <i class="bi bi-plus-lg"></i> @Loc["Add First Package"]
                </button>
            }
        </div>
    }

    <div class="details-back-section">
        <button class="details-back-btn" @onclick="GoBack">
            <i class="bi bi-arrow-left"></i> @Loc["Back"]
        </button>
    </div>
</div>

@if (_showQrModal)
{
    <div class="qr-overlay" @onclick="() => _showQrModal = false">
        <div class="qr-lightbox" @onclick:stopPropagation>
            <button class="qr-close-btn" @onclick="() => _showQrModal = false">&times;</button>
            <img src="@GetBusinessImage()" class="qr-lightbox-banner" alt="@Business?.Name" />
            <div class="qr-lightbox-body">
                <h2 class="qr-lightbox-name">@Business?.Name</h2>
                <img src="@GetQRUrl()" alt="QR Code for @Business?.Name" class="qr-lightbox-img" />
                <p class="qr-lightbox-hint">Scan to share this business</p>
            </div>
        </div>
    </div>
}


