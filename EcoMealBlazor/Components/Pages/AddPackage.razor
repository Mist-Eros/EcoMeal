@page "/business/{BusinessId:int}/addpackage"
@inherits AddPackageBase
@rendermode InteractiveServer
@using EcoMeal.EcoMealBlazor.Models
@using System.ComponentModel.DataAnnotations
@using EcoMeal.EcoMealBlazor.Services
@using Microsoft.Extensions.Localization
@using EcoMeal.EcoMealBlazor.Resources
@inject NavigationManager NavigationManager
@inject BusinessService BusinessService
@inject IStringLocalizer<SharedResource> Loc

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card form-card">
                <div class="card-body p-4">
                    <h2 class="card-title fw-bold text-success mb-4">
                        <i class="bi bi-plus-circle me-2"></i>@Loc["Add Package"]
                    </h2>

                    <EditForm Model="Model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">@Loc["Name"]</label>
                            <InputText class="form-control rounded-pill dark-input" @bind-Value="Model.Name" placeholder="Package name..." />
                            <ValidationMessage For="@(() => Model.Name)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <InputTextArea class="form-control rounded-4 dark-input" @bind-Value="Model.Description" placeholder="Describe the package..." rows="3" />
                            <ValidationMessage For="@(() => Model.Description)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Price (RON)</label>
                            <InputNumber class="form-control rounded-pill dark-input" @bind-Value="Model.Price" placeholder="0.00" step="0.01" min="0" />
                            <ValidationMessage For="@(() => Model.Price)" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Pickup Date</label>
                            <input type="date" class="form-control rounded-pill dark-input" @bind="_pickupDate" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Start Time</label>
                                <input type="time" class="form-control rounded-pill dark-input" @bind="_startTime" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">End Time</label>
                                <input type="time" class="form-control rounded-pill dark-input" @bind="_endTime" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Package Type</label>
                            <InputSelect class="form-select rounded-pill dark-input" @bind-Value="Model.PackageTypeId">
                                <option value="">Select a type...</option>
                                @foreach (var type in PackageTypes)
                                {
                                    <option value="@type.Id">@type.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => Model.PackageTypeId)" class="text-danger small" />
                        </div>

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger">@ErrorMessage</div>
                        }

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-form-save" disabled="@IsSubmitting">
                                @if (IsSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                <i class="bi bi-check-lg me-1"></i> @Loc["Save"]
                            </button>
                            <button type="button" class="btn-form-cancel" @onclick="GoBack">
                                @Loc["Cancel"]
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

