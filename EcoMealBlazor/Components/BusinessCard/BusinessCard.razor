@namespace EcoMeal.EcoMealBlazor.Components.BusinessCard

<div class="card" style="width: 18rem;">
  <!--
    <img src="..." class="card-img-top" alt="...">
    this is how we add an image but we dont need it
  -->
  <div class="card-body">
    <h5 class="card-title">@Business.Name</h5>
    <p class="card-text">@Business.Description</p>
    <p class="card-text">@Business.Address</p>
    <p class="card-text">@Business.Contact</p>
    <button class="btn btn-danger" @onclick="DeleteBusiness">
        Delete this Business
    </button>
  </div>
</div>