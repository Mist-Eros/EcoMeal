@namespace EcoMeal.EcoMealBlazor.Components.BusinessCard

<div class="card h-100 shadow-sm rounded-4 overflow-hidden" @onclick="NavigateToDetails" style="cursor: pointer; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
    <img src="@GetBusinessImage()" class="card-img-top" alt="@Business.Name" style="height: 180px; object-fit: cover;" />
    <div class="card-body d-flex flex-column">
        <div>
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title text-success fw-bold mb-0">@Business.Name</h5>
                <span class="badge rounded-pill px-3 py-2" style="background: linear-gradient(180deg, #1a472a 0%, #2d6a4f 40%, #40916c 100%); color: white; border: none;">@Business.BusinessTypeName</span>
            </div>
            <p class="card-text text-muted small">@Business.Description</p>
            <p class="card-text text-muted small"><i class="bi bi-geo-alt"></i> @Business.Address</p>
            <p class="card-text text-muted small"><i class="bi bi-telephone"></i> @Business.Contact</p>
        </div>
        
        <div class="mt-auto pt-3">
            @if (_isAdmin)
            {
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary rounded-pill flex-fill" @onclick="EditBusiness" @onclick:stopPropagation="true">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                    <button class="btn btn-outline-danger rounded-pill flex-fill" @onclick="DeleteBusiness" @onclick:stopPropagation="true">
                        <i class="bi bi-trash3"></i> Delete
                    </button>
                </div>
            }
            else
            {
                <button class="btn btn-success rounded-pill w-100" @onclick="OrderBusiness" @onclick:stopPropagation="true">
                    <i class="bi bi-cart"></i> Order
                </button>
            }
        </div>
    </div>
</div>