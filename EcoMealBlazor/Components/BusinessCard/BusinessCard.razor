@namespace EcoMeal.EcoMealBlazor.Components.BusinessCard

<div class="card h-100 shadow-sm">
  <div class="card-body">
    <h5 class="card-title text-success fw-bold">@Business.Name</h5>
    <p class="card-text">@Business.Description</p>
    <p class="card-text text-muted"><i class="bi bi-geo-alt"></i> @Business.Address</p>
    <p class="card-text text-muted"><i class="bi bi-telephone"></i> @Business.Contact</p>
    <button class="btn btn-danger w-100 mt-2" @onclick="DeleteBusiness">
        <i class="bi bi-trash3"></i> Delete
    </button>
  </div>
</div>